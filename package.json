{
  "name": "r3f-crawl-lib",
  "version": "0.1.0",
  "description": "Composable first-person dungeon crawl library for React Three Fiber",
  "type": "module",
  "main": "dist/r3f-crawl-lib.umd.js",
  "module": "dist/r3f-crawl-lib.js",
  "types": "dist/index.d.ts",
  "browser": "dist/r3f-crawl-lib.iife.js",
  "exports": {
    ".": {
      "browser": "./dist/r3f-crawl-lib.iife.js",
      "import": "./dist/r3f-crawl-lib.js",
      "require": "./dist/r3f-crawl-lib.umd.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc && vite build",
    "build:server": "vite build --config vite.config.server.ts",
    "typecheck": "tsc --noEmit",
    "dev": "vite build --watch",
    "examples": "npx serve .",
    "multiplayer": "npm run build:server && node src/server/index.js"
  },
  "peerDependencies": {
    "@react-three/drei": ">=9",
    "@react-three/fiber": ">=8",
    "react": ">=18",
    "react-dom": ">=18",
    "three": ">=0.160"
  },
  "devDependencies": {
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/three": "^0.178.0",
    "@vitejs/plugin-react": "^6.0.1",
    "express": "^4.22.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "three": "^0.183.2",
    "typescript": "^5.9.3",
    "vite": "^8.0.1",
    "vite-plugin-dts": "^4.5.4",
    "ws": "^8.20.0"
  }
}
