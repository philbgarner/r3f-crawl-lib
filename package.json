{
  "name": "atomic-core",
  "version": "0.6.3",
  "description": "Composable first-person dungeon crawl library for React Three Fiber",
  "type": "module",
  "main": "dist/atomic-core.umd.cjs",
  "module": "dist/atomic-core.js",
  "types": "dist/index.d.ts",
  "browser": "dist/atomic-core.iife.js",
  "jsdelivr": "dist/atomic-core.iife.js",
  "exports": {
    ".": {
      "browser": "./dist/atomic-core.iife.js",
      "import": "./dist/atomic-core.js",
      "require": "./dist/atomic-core.umd.cjs",
      "types": "./dist/index.d.ts"
    },
    "./style.css": "./dist/atomic-core.css"
  },
  "bin": {
    "atomic-core-server": "src/server/index.js"
  },
  "files": [
    "dist",
    "src/server/index.js"
  ],
  "dependencies": {
    "express": "^4.22.1",
    "ws": "^8.20.0"
  },
  "scripts": {
    "docs": "typedoc",
    "build": "tsc && vite build",
    "build:server": "vite build --config vite.config.server.ts",
    "build:watch": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "dev": "vite build --watch",
    "multiplayer": "npm run build:server && node src/server/index.js",
    "examples": "npx serve ."
  },
  "peerDependencies": {
    "@react-three/drei": ">=9",
    "@react-three/fiber": ">=8",
    "react": ">=18",
    "react-dom": ">=18",
    "three": ">=0.160"
  },
  "devDependencies": {
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/three": "^0.178.0",
    "@vitejs/plugin-react": "^6.0.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "three": "^0.183.2",
    "typedoc": "^0.28.19",
    "typedoc-plugin-markdown": "^4.11.0",
    "typescript": "^5.9.3",
    "vite": "^8.0.1",
    "vite-plugin-dts": "^4.5.4",
    "ws": "^8.20.0"
  }
}
